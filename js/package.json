{
	"name": "finpass",
	"version": "1.0.0",
	"description": "Finnish Passphrase Generator",
	"type": "module",
	"scripts": {
		"build": "bun run build.ts",
		"dev": "bun run --watch build.ts",
		"clean": "rm -rf dist/*",
		"type-check": "tsc --noEmit",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"format": "biome format --write ."
	},
	"devDependencies": {
		"@biomejs/biome": "^2.3.8",
		"@types/bun": "latest",
		"typescript": "^5.0.0"
	}
}
